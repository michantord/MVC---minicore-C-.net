@model ComisionesVentas.Models.ComisionViewModel
@{
    ViewData["Title"] = "Calcular Comisiones";
}

<h1 class="mb-4 text-center" style="color: #2c3e50;">Calcular Comisiones</h1>

<div class="container">
    <form class="bg-light mb-4 rounded p-3 shadow-sm" id="filterForm" method="get" action="/Home/Index">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Fecha Inicial</label>
                <input type="date" name="startDate" id="startDate" class="form-control" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Fecha Final</label>
                <input type="date" name="endDate" id="endDate" class="form-control" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Vendedor</label>
                <select name="vendedorId" id="vendedorId" class="form-select">
                    <option value="">Todos</option>
                    @foreach (var v in Model.Vendedores)
                    {
                        if (Model.VendedorId == v.Id)
                        {
                            <option value="@v.Id" selected>@v.Nombre</option>
                        }
                        else
                        {
                            <option value="@v.Id">@v.Nombre</option>
                        }
                    }
                </select>
            </div>
        </div>
        <div class="mt-3 text-center">
            <button type="submit" class="btn btn-lg text-white shadow-sm" style="background-color: #6f42c1; border-color: #6f42c1; transition: all 0.3s ease;">Calcular</button>
        </div>
    </form>

    <h2 class="mb-4 text-center" style="color: #2c3e50;">Resultados</h2>
    <div class="table-responsive">
        <table class="table-striped table-hover table-bordered table" id="resultsTable">
            <thead class="table-dark">
                <tr>
                    <th>ID Venta</th>
                    <th>Fecha</th>
                    <th>Monto</th>
                    <th>Vendedor</th>
                    <th>% Comisión</th>
                    <th>Comisión</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @if (Model.Resultados.Count == 0)
                {
                    <tr>
                        <td colspan="6" class="text-center">No se encontraron resultados</td>
                    </tr>
                }
                else
                {
                    @foreach (var sale in Model.Resultados)
                    {
                        <tr>
                            <td>@sale.Id</td>
                            <td>@sale.Fecha.ToShortDateString()</td>
                            <td>$@sale.Monto.ToString("0.00")</td>
                            <td>@sale.Vendedor?.Nombre</td>
                            <td>@sale.PorcentajeComision%</td>
                            <td>$@sale.Comision.ToString("0.00")</td>
                        </tr>
                    }
                }
            </tbody>
            @if (Model.Resultados.Count > 0)
            {
                <tfoot class="table-dark" id="tableFoot">
                    <tr>
                        <td colspan="5" class="fw-bold text-end">Total Comisión:</td>
                        <td class="fw-bold" id="totalCommission">$@Model.TotalComision.ToString("0.00")</td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</div>
